# Platform to use: "discord" or "slack"
PLATFORM=discord

# Gateway auth — clients must send this as Bearer token
AGENT_GATEWAY_API_KEY=change-me

# Discord (required when PLATFORM=discord)
DISCORD_BOT_TOKEN=

# Slack (required when PLATFORM=slack)
SLACK_BOT_TOKEN=

# Server
PORT=3000
RUST_LOG=info
